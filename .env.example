# =============================================================================
# Sprout OS Orbit — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — NEVER commit real credentials.
# =============================================================================

# ── Target URL ────────────────────────────────────────────────────────────────
# The base URL to run tests against.
# Default: https://sproutos.ai (production)
# Override with staging URL when testing pre-release builds.
SPROUTOS_URL=https://sproutos.ai

# ── Standard test account (regular user role) ────────────────────────────────
# Used by all auth-gated E2E tests (dashboard, design editor, sitemap, etc.)
TEST_USER_EMAIL=qa@yourworkspace.com
TEST_USER_PASSWORD=ReplaceWithSecurePassword

# ── Admin / owner test account ────────────────────────────────────────────────
# Required for team management, billing, and workspace-owner-gated tests.
TEST_ADMIN_EMAIL=admin@yourworkspace.com
TEST_ADMIN_PASSWORD=ReplaceWithSecurePassword

# ── Manage Mode test site (WordPress + Sprout OS plugin via Docker) ───────────
# WordPress site used by Manage Mode / MCP integration tests.
# Must have the Sprout OS WordPress plugin installed and activated.
TEST_WP_SITE_URL=http://localhost:8090
TEST_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Docker container details (matches your GitHub-authorized Docker setup)
WP_DOCKER_CONTAINER=sproutos-wp
WP_PORT=8090
WP_DB_NAME=sproutos_qa
WP_DB_USER=sproutos
WP_DB_PASSWORD=ReplaceWithSecurePassword
WP_DB_ROOT_PASSWORD=ReplaceWithSecurePassword
WP_ADMIN_USER=qa_admin
WP_ADMIN_PASSWORD=ReplaceWithSecurePassword
WP_ADMIN_EMAIL=qa@sproutos-test.local

# ── Second workspace member (for invite / team tests) ────────────────────────
TEST_MEMBER_EMAIL=member@yourworkspace.com
TEST_MEMBER_PASSWORD=ReplaceWithSecurePassword

# ── Invited (not-yet-joined) user ────────────────────────────────────────────
# Used to test the invite acceptance flow.
TEST_INVITE_EMAIL=invite-test@example.com

# ── Playwright options ────────────────────────────────────────────────────────
# Set to 1 to run tests in headed (visible browser) mode.
# PW_HEADED=1

# Number of parallel workers (default is set in playwright.config.js).
# PW_WORKERS=4

# ── Lighthouse / report output ────────────────────────────────────────────────
# Optional: override where reports are written.
# REPORT_DIR=reports

# ── Auth state storage ────────────────────────────────────────────────────────
# Playwright storageState files — auto-created by global setup.
# AUTH_STATE_USER=tests/.auth/user.json
# AUTH_STATE_ADMIN=tests/.auth/admin.json
