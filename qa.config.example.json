{
  "_comment": "Copy this file to qa.config.json and fill in your details. qa.config.json is gitignored — never commit credentials.",

  "product": {
    "name": "Sprout OS",
    "type": "saas-web",
    "version": "1.0.0",
    "team": "Sprout OS QA"
  },

  "properties": {
    "sproutos": {
      "name": "Sprout OS",
      "url": "https://sproutos.ai",
      "testAreas": [
        "landing",
        "auth-login",
        "auth-signup",
        "auth-forgot-password",
        "dashboard",
        "pricing",
        "settings",
        "security-headers",
        "seo"
      ]
    }
  },

  "environment": {
    "qaEmail": "qa@example.com",
    "qaPassword": "ReplaceMe",
    "stagingUrl": "",
    "runAgainst": "production"
  },

  "competitors": [
    "https://vercel.com",
    "https://railway.app",
    "https://render.com"
  ],

  "qaFocus": {
    "priority": "full",
    "testAreas": [
      "auth",
      "landing",
      "dashboard",
      "pricing",
      "security",
      "responsive",
      "accessibility",
      "visual-regression"
    ]
  },

  "thresholds": {
    "lighthouse": {
      "performance": 75,
      "accessibility": 85,
      "bestPractices": 80,
      "seo": 80
    },
    "jsBundleKb": 500,
    "cssBundleKb": 200,
    "pageLoadMs": 4000
  },

  "viewports": {
    "mobile": { "width": 375, "height": 812 },
    "tablet": { "width": 768, "height": 1024 },
    "desktop": { "width": 1440, "height": 900 }
  },

  "reporting": {
    "outputDir": "reports",
    "screenshotsDir": "reports/screenshots",
    "snapshotsDir": "tests/snapshots",
    "htmlReport": "reports/playwright-html"
  }
}
