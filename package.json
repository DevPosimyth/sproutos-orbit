{
  "name": "sproutos-orbit",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright test --reporter=html",
    "test:ai": "playwright test --reporter=json",
    "test:login": "playwright test tests/sproutos/login-pages.spec.js",
    "test:dashboard": "playwright test tests/sproutos/dashboard/",
    "test:dashboard-home": "playwright test tests/sproutos/dashboard/home.spec.js",
    "test:dashboard-sidebar": "playwright test tests/sproutos/dashboard/sidebar.spec.js",
    "test:dashboard-workspace": "playwright test tests/sproutos/dashboard/workspace.spec.js",
    "test:dashboard-settings": "playwright test tests/sproutos/dashboard/settings.spec.js",
    "test:dashboard-security": "playwright test tests/sproutos/dashboard/security.spec.js",
    "test:homepage": "playwright test tests/sproutos/homepage.spec.js",
    "test:sitemap": "playwright test tests/sproutos/sitemap.spec.js",
    "test:scope": "playwright test tests/sproutos/scope.spec.js",
    "test:design": "playwright test tests/sproutos/design.spec.js",
    "dashboard:report": "bash scripts/dashboard-report.sh",
    "qa": "bash scripts/run-all-tests.sh",
    "qa:quick": "bash scripts/run-all-tests.sh --quick",
    "qa:full": "bash scripts/run-all-tests.sh --html",
    "qa:lighthouse": "bash scripts/lighthouse.sh",
    "qa:lighthouse:desktop": "bash scripts/lighthouse.sh --desktop-only",
    "qa:lighthouse:mobile": "bash scripts/lighthouse.sh --mobile-only",
    "qa:seo": "bash scripts/run-all-tests.sh --skip-lighthouse --skip-a11y --skip-links --quick",
    "qa:a11y": "bash scripts/run-all-tests.sh --skip-lighthouse --skip-seo --skip-links --quick"
  },
  "keywords": ["sproutos", "qa", "playwright", "automation", "posimyth"],
  "author": "POSIMYTH",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "fs-extra": "^11.3.4",
    "path": "^0.12.7",
    "playwright": "^1.59.1",
    "unzipper": "^0.12.3",
    "zod": "^4.3.6"
  },
  "directories": {
    "test": "tests"
  },
  "description": "QA Automation framework for Sprout OS (sproutos.ai) — POSIMYTH's AI-powered SaaS platform."
}
